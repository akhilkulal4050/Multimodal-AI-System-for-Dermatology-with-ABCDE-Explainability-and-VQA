@article{reviewunet2024_unetreview,
author = {Kumar, S. S. and Vinod Kumar, R. S. and Subbulekshmi, D.},
title = {A Review of U-Net-Based Deep Learning Models for Skin Lesion Segmentation},
journal = {International Journal of Imaging Systems and Technology},
volume = {35},
number = {3},
pages = {e70107},
keywords = {computer-aided diagnosis, deep learning, medical image analysis, skin lesion segmentation, U-net},
doi = {https://doi.org/10.1002/ima.70107},
url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/ima.70107},
eprint = {https://onlinelibrary.wiley.com/doi/pdf/10.1002/ima.70107},
note = {e70107 IMA-25-401.R1},
abstract = {ABSTRACT Automated skin lesion segmentation is crucial for early and accurate skin cancer diagnosis. Deep learning, particularly U-Net, has revolutionized the field of automatic skin lesion segmentation. This review comprehensively examines U-Net and its variants employed for automated skin lesion segmentation. It outlines the foundational U-Net architecture and explores diverse architectural innovations, including attention mechanisms, advanced skip connections, residual and dilated convolutions, transformer models, and hybrid models. The review highlights how these adaptations address inherent challenges in skin lesion segmentation, including data limitations and lesion heterogeneity. It also discusses the commonly used datasets, evaluation metrics, and compares model performance and computational cost. Finally, it addresses the existing challenges and outlines future research directions to advance automated skin cancer diagnosis.},
year = {2025}
}




