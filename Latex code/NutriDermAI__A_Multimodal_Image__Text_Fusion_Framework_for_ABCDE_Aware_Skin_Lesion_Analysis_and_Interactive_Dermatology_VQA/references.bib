@article{aboulmira2025_attentionmultiskin,
title = {Attention-guided multimodal skin disease classification using discounted Dempster–Shafer fusion and EfficientNet},
journal = {Informatics in Medicine Unlocked},
volume = {58},
pages = {101699},
year = {2025},
issn = {2352-9148},
doi = {https://doi.org/10.1016/j.imu.2025.101699},
url = {https://www.sciencedirect.com/science/article/pii/S2352914825000887},
author = {Amina Aboulmira and Hamid Hrimech and Mohamed Lachgar and Hamza Malyana and Khalid Lemouden},
keywords = {Skin lesion, Classification, Dempster–Shafer, Belief function, Image processing, Convolutional Neural Networks},
abstract = {Skin diseases represent a significant global health challenge, with skin cancer being the most commonly diagnosed cancer worldwide according to the World Health Organization. Traditional diagnostic methods often rely on visual or biopsy examination, which can be time-consuming and may leave scars on the skin. This approach lacks precision and can delay the initiation of treatment, highlighting the need for alternative diagnostic methods. This study presents a novel multimodal architecture for skin disease classification that combines dermoscopic images and structured clinical metadata. By employing a discounted evidential fusion framework with attention, where each modality independently generates belief mass distributions using an attention-enhanced dense network. These distributions are then adaptively fused using a modified Dempster–Shafer theory, where modality-specific reliability coefficients (α1, α2) adjust the weight of each input based on its contextual trustworthiness. The fused beliefs are concatenated with deep image and tabular features for classification, enabling the network to integrate both semantic and probabilistic reasoning. This approach was tested on four benchmark datasets: HAM10000, ISIC 2019, ISIC 2020 and PAD-UFES-20. Results confirm its generalizability and demonstrating the power of combining these two modalities with probabilistic fusion methods to address the challenges inherent in diagnosing skin diseases, paving the way for more effective and efficient healthcare solutions.}
}

